generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ User (Auth) ============
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String                    // bcrypt hashed
  role          String   @default("free") // "free" | "pro" | "admin"
  avatar        String?
  emailVerified DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dramas Drama[]
  userProviders UserProvider[]
}

// ============ Drama Project ============
model Drama {
  id            String   @id @default(cuid())
  title         String
  description   String   @default("")
  genre         String   @default("都市")
  style         String   @default("realistic")
  coverImage    String?
  totalEpisodes Int      @default(0)
  status        String   @default("draft")
  userId              String?                    // nullable for backward compat
  defaultLockedConfig String   @default("null")  // JSON: { llm?: string, image?: string, video?: string, tts?: string } — "null" = no default lock
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes   Episode[]
  characters Character[]
  scenes     Scene[]
  generationCosts GenerationCost[]
}

// ============ Episode ============
model Episode {
  id            String   @id @default(cuid())
  dramaId       String
  episodeNumber Int
  title         String   @default("")
  rawContent    String?
  scriptContent String?
  scriptStatus  String   @default("pending")
  extractStatus String   @default("pending")
  storyboardStatus String @default("pending")
  status        String   @default("draft")
  lockedConfig  String   @default("null")  // JSON: { llm?: string, image?: string, video?: string, tts?: string } — "null" = no lock
  videoUrl      String?
  duration      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  drama        Drama        @relation(fields: [dramaId], references: [id], onDelete: Cascade)
  storyboards  Storyboard[]

  @@unique([dramaId, episodeNumber])
}

// ============ Character ============
model Character {
  id          String   @id @default(cuid())
  dramaId     String
  name        String
  role        String   @default("supporting")
  gender      String   @default("unknown")
  age         String   @default("")
  appearance  String   @default("")
  personality String   @default("")
  voiceStyle  String   @default("")
  voiceId     String?
  imagePrompt String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drama       Drama                @relation(fields: [dramaId], references: [id], onDelete: Cascade)
  appearances CharacterAppearance[]
}

// ============ Scene ============
model Scene {
  id          String   @id @default(cuid())
  dramaId     String
  location    String
  timeOfDay   String   @default("day")
  description String   @default("")
  prompt      String   @default("")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drama  Drama       @relation(fields: [dramaId], references: [id], onDelete: Cascade)
  images SceneImage[]
}

// ============ Storyboard (Shot) ============
model Storyboard {
  id              String   @id @default(cuid())
  episodeId       String
  shotNumber      Int
  title           String   @default("")
  shotType        String   @default("medium")
  cameraAngle     String   @default("eye-level")
  cameraMovement  String   @default("static")
  action          String   @default("")
  description     String   @default("")  // Visual description for the shot
  dialogue        String?
  dialogueChar    String?
  duration        Float    @default(3.0)
  imagePrompt     String?
  videoPrompt     String?
  atmosphere      String?
  firstFrameUrl   String?
  lastFrameUrl    String?
  videoUrl        String?
  ttsAudioUrl     String?
  composedUrl     String?
  bgmPrompt       String?
  soundEffect     String?
  referenceImages String?  // JSON array of reference image URLs
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
}

// ============ Character Appearance (NEW - 核心资产沉淀) ============
model CharacterAppearance {
  id               String   @id @default(cuid())
  characterId      String
  appearanceIndex  Int      @default(0)  // 0 = primary/主形象, 1+ = sub-appearances
  label            String   @default("")  // e.g., "主形象", "夜晚形态", "战斗形态"
  description      String   @default("")  // Text description extracted by AI Vision
  imagePrompt      String   @default("")  // The prompt used for generation
  imageUrl         String?               // Currently selected image (data URL or path)
  imageUrls        String   @default("[]") // JSON array of all generated images
  selectedIndex    Int      @default(0)   // Which image in imageUrls is selected
  previousImageUrl String?              // For undo/rollback
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, appearanceIndex])
}

// ============ Scene Image (NEW - 核心资产沉淀) ============
model SceneImage {
  id          String   @id @default(cuid())
  sceneId     String
  description String   @default("")  // Text prompt used for generation
  imageUrl    String?               // Generated image (data URL or path)
  timeOfDay   String   @default("")  // "day", "night", "dusk", etc.
  angle       String   @default("")  // "wide", "medium", "close-up"
  isSelected  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
}

// ============ Image Generation (NEW - 图片生成追踪) ============
model ImageGeneration {
  id              String   @id @default(cuid())
  storyboardId    String?
  characterId     String?
  sceneId         String?
  dramaId         String?
  prompt          String
  model           String   @default("")
  provider        String   @default("")
  size            String   @default("1024x1024")
  frameType       String?  // "first_frame", "last_frame", "character_portrait", "scene_establishing", "storyboard_frame"
  referenceImages String?  // JSON array of reference image URLs used
  taskId          String?  // Async task ID for polling
  imageUrl        String?  // Final image URL
  status          String   @default("pending")  // pending, processing, completed, failed
  errorMsg        String?
  tokensUsed      Int?     // Estimated tokens consumed
  generationMs    Int?     // Generation latency in milliseconds
  costCredits     Float    @default(0)  // Normalized cost credits (1 credit ≈ 1 standard image)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ AI Provider Configuration ============
model AiProvider {
  id          String   @id @default(cuid())
  category    String   // "llm" | "image" | "video" | "tts"
  provider    String   // "nvidia" | "openai" | "stability" | "z-ai-sdk" | "siliconflow" | "volcengine" | "fish-audio" | custom
  name        String   // Display name
  apiKey      String   @default("")
  baseUrl     String   @default("")
  model       String   @default("")
  isActive    Boolean  @default(false)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, provider])
}

// ============ User Provider Configuration ============
// Per-user API key overrides — when set, takes priority over global AiProvider
model UserProvider {
  id          String   @id @default(cuid())
  userId      String
  category    String   // "llm" | "image" | "video" | "tts"
  provider    String   // "openai" | "siliconflow" | etc.
  apiKey      String   @default("")
  baseUrl     String   @default("")
  model       String   @default("")
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, provider])
}

// ============ Agent Configuration ============
model AgentConfig {
  id          String   @id @default(cuid())
  agentType   String   @unique  // "script_rewriter" | "extractor" | "storyboard_breaker" | "voice_assigner" | "grid_prompt_generator"
  systemPrompt String?
  model       String?
  temperature Float    @default(0.7)
  maxTokens   Int      @default(4096)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ Video Generation Tracking ============
model VideoGeneration {
  id              String   @id @default(cuid())
  storyboardId    String?
  dramaId         String?
  provider        String   @default("")
  model           String   @default("")
  prompt          String   @default("")
  referenceMode   String?  // "first_frame", "first_last", "text_only"
  firstFrameUrl   String?
  lastFrameUrl    String?
  duration        Int      @default(5)
  aspectRatio     String   @default("16:9")
  taskId          String?  // Async task ID for polling
  videoUrl        String?
  status          String   @default("pending") // pending, processing, completed, failed
  errorMsg        String?
  tokensUsed      Int?     // Estimated tokens consumed
  generationMs    Int?     // Generation latency in milliseconds
  costCredits     Float    @default(0)  // Normalized cost credits (1 credit ≈ 5s standard video)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ Generation Cost Tracking ============
model GenerationCost {
  id          String   @id @default(cuid())
  dramaId     String
  episodeId   String?  // null = drama-level
  category    String   // "image" | "video" | "tts" | "llm"
  provider    String
  model       String
  credits     Float    @default(0)
  tokensUsed  Int      @default(0)
  count       Int      @default(1)  // Number of generations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drama       Drama    @relation(fields: [dramaId], references: [id])
}

// ============ Video Merge Tracking ============
model VideoMerge {
  id          String   @id @default(cuid())
  episodeId   String
  dramaId     String?
  status      String   @default("pending") // pending, processing, completed, failed
  mergedUrl   String?
  duration    Int      @default(0)
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
